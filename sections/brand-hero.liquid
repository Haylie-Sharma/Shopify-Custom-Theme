<section class="brand-hero color-{{ section.settings.color_scheme }}" data-brand-hero="{{ section.id }}" data-auto-seconds="{{ section.settings.auto_rotate_seconds }}" style="padding-top: calc(var(--spacing-unit, 2rem) * {{ section.settings.spacing_top }}); padding-bottom: calc(var(--spacing-unit, 2rem) * {{ section.settings.spacing_bottom }});">
  <div class="brand-hero-slider">
    {% assign has_valid_image_slide = false %}
    {% for block in section.blocks %}
      {% if block.settings.image != blank %}
        {% assign has_valid_image_slide = true %}
      {% endif %}
    {% endfor %}
    {% if section.blocks.size > 0 and has_valid_image_slide %}
      {% assign rendered_slide_index = 0 %}
      {% for block in section.blocks %}
        {% if block.settings.image != blank %}
          <article class="brand-hero-slide{% if rendered_slide_index == 0 %} is-active{% endif %}" data-hero-slide {{ block.shopify_attributes }}>
            <img
              src="{{ block.settings.image | image_url: width: 1800 }}"
              alt="{{ block.settings.title }}"
              class="brand-hero-slide__image"
              loading="lazy"
              width="1400"
              height="700"
            >
            <div class="page-width brand-hero__inner">
              <p class="brand-hero__eyebrow">{{ block.settings.eyebrow }}</p>
              <h1 class="brand-hero__title">{{ block.settings.title }}</h1>
              <p class="brand-hero__subtitle">{{ block.settings.subtitle }}</p>
              <div class="brand-hero__actions">
                {% if block.settings.primary_button_label != blank and block.settings.primary_button_link != blank %}
                  <a href="{{ block.settings.primary_button_link }}" class="brand-button brand-button--primary">{{ block.settings.primary_button_label }}</a>
                {% endif %}
                {% if block.settings.secondary_button_label != blank and block.settings.secondary_button_link != blank %}
                  <a href="{{ block.settings.secondary_button_link }}" class="brand-button brand-button--secondary">{{ block.settings.secondary_button_label }}</a>
                {% endif %}
              </div>
            </div>
          </article>
          {% assign rendered_slide_index = rendered_slide_index | plus: 1 %}
        {% endif %}
      {% endfor %}
    {% else %}
      <article class="brand-hero-slide is-active" data-hero-slide>
        <div class="page-width brand-hero__inner">
          <p class="brand-hero__eyebrow">{{ section.settings.eyebrow }}</p>
          <h1 class="brand-hero__title">{{ section.settings.title }}</h1>
          <p class="brand-hero__subtitle">{{ section.settings.subtitle }}</p>
          <div class="brand-hero__actions">
            {% if section.settings.primary_button_label != blank and section.settings.primary_button_link != blank %}
              <a href="{{ section.settings.primary_button_link }}" class="brand-button brand-button--primary">{{ section.settings.primary_button_label }}</a>
            {% endif %}
            {% if section.settings.secondary_button_label != blank and section.settings.secondary_button_link != blank %}
              <a href="{{ section.settings.secondary_button_link }}" class="brand-button brand-button--secondary">{{ section.settings.secondary_button_label }}</a>
            {% endif %}
          </div>
        </div>
      </article>
    {% endif %}
  </div>

</section>

<script>
  (function() {
    var root = document.querySelector('[data-brand-hero={{ section.id | json }}]');
    if (!root) return;
    var slides = root.querySelectorAll('[data-hero-slide]');
    if (slides.length < 2) return;

    var index = 0;
    var seconds = Number(root.getAttribute('data-auto-seconds') || 5);
    var intervalMs = Math.max(3, seconds) * 1000;
    var timer;

    function show(nextIndex) {
      index = (nextIndex + slides.length) % slides.length;
      slides.forEach(function(slide, i) {
        slide.classList.toggle('is-active', i === index);
      });
    }

    function startAuto() {
      clearInterval(timer);
      timer = setInterval(function() {
        show(index + 1);
      }, intervalMs);
    }

    startAuto();
  })();
</script>

{% schema %}
{
  "name": "Brand hero",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Full width section",
      "default": true
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "select",
      "id": "spacing_top",
      "label": "Spacing - Top",
      "options": [
        {"value": "0", "label": "None"},
        {"value": "1", "label": "Extra Small"},
        {"value": "2", "label": "Small"},
        {"value": "3", "label": "Medium"},
        {"value": "4", "label": "Large"},
        {"value": "5", "label": "Extra Large"}
      ],
      "default": "0"
    },
    {
      "type": "select",
      "id": "spacing_bottom",
      "label": "Spacing - Bottom",
      "options": [
        {"value": "0", "label": "None"},
        {"value": "1", "label": "Extra Small"},
        {"value": "2", "label": "Small"},
        {"value": "3", "label": "Medium"},
        {"value": "4", "label": "Large"},
        {"value": "5", "label": "Extra Large"}
      ],
      "default": "0"
    },
    {
      "type": "header",
      "content": "Color"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "options": [
        {"value": "background-1", "label": "Default"},
        {"value": "background-2", "label": "Secondary"},
        {"value": "inverse", "label": "Inverse"},
        {"value": "accent-1", "label": "Accent 1"},
        {"value": "accent-2", "label": "Accent 2"}
      ],
      "default": "background-1"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Timeless handbags for modern women"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Signature purses crafted for everyday elegance"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Discover versatile silhouettes, premium materials, and thoughtful details designed to carry your day beautifully."
    },
    {
      "type": "text",
      "id": "primary_button_label",
      "label": "Primary button label",
      "default": "Shop New Arrivals"
    },
    {
      "type": "url",
      "id": "primary_button_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_button_label",
      "label": "Secondary button label",
      "default": "Explore Collections"
    },
    {
      "type": "url",
      "id": "secondary_button_link",
      "label": "Secondary button link"
    },
    {
      "type": "range",
      "id": "auto_rotate_seconds",
      "label": "Auto-rotate every",
      "min": 3,
      "max": 9,
      "step": 1,
      "unit": "s",
      "default": 5
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "New in" },
        { "type": "text", "id": "title", "label": "Title", "default": "Made for every moment" },
        { "type": "textarea", "id": "subtitle", "label": "Subtitle", "default": "Carry elevated styles from desk drops to weekend plans." },
        { "type": "text", "id": "primary_button_label", "label": "Primary button label", "default": "Shop now" },
        { "type": "url", "id": "primary_button_link", "label": "Primary button link" },
        { "type": "text", "id": "secondary_button_label", "label": "Secondary button label", "default": "View collection" },
        { "type": "url", "id": "secondary_button_link", "label": "Secondary button link" }
      ]
    }
  ],
  "max_blocks": 5,
  "presets": [
    {
      "name": "Brand hero",
      "blocks": [
        { "type": "slide" },
        { "type": "slide" }
      ]
    }
  ]
}
{% endschema %}
