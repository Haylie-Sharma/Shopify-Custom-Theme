<header class="header-section">
  {% if section.settings.show_announcement and section.settings.announcement_text != blank %}
    <div class="header-announcement">
      <div class="header-announcement__inner">
        <div class="header-announcement__track">
          {% for i in (1..8) %}
            <span class="header-announcement__item">{{ section.settings.announcement_text }}</span>
          {% endfor %}
        </div>
      </div>
    </div>
  {% endif %}

  <div class="header page-width">
    <div class="header__left">
      {% if section.settings.search_enabled %}
        <button type="button" class="header__icon-link header__search-toggle" data-header-search-toggle="{{ section.id }}" aria-expanded="false" aria-controls="header-search-{{ section.id }}">Search</button>
      {% endif %}
    </div>

    <div class="header__logo">
      <a href="{{ shop.url }}" class="header__logo-link">
        {% if settings.logo_image != blank %}
          <img src="{{ settings.logo_image | image_url: width: 420 }}" alt="{{ shop.name }}" class="header__logo-image" width="200" height="60">
        {% else %}
          <span class="header__logo-text">{{ shop.name }}</span>
        {% endif %}
      </a>
    </div>

    <div class="header__utilities">
      <a href="{% if customer %}/account{% else %}/account/login{% endif %}" class="header__icon-link" aria-label="Account">Account</a>
      <a href="{{ routes.cart_url }}" class="header__icon-link" aria-label="Cart">Cart ({{ cart.item_count }})</a>
    </div>
  </div>

  {% if section.settings.search_enabled %}
    <div class="header__search-wrapper" id="header-search-{{ section.id }}" data-header-search-wrapper="{{ section.id }}">
      <script src="{{ 'predictive-search.js' | asset_url }}" defer="defer"></script>
      <predictive-search>
        <form action="/search" method="get" role="search" class="header__search-form predictive-search-form">
          <label class="visually-hidden" for="HeaderSearch">Search</label>
          <input
            id="HeaderSearch"
            class="header__search-input"
            type="search"
            name="q"
            placeholder="Search our store"
            aria-label="Search our store"
            aria-autocomplete="list"
            aria-expanded="false"
            aria-owns="predictive-search-results-header"
            aria-controls="predictive-search-results-header"
          />
          <input name="options[prefix]" type="hidden" value="last" />
          <button type="submit" class="header__search-button">Search</button>
          <button type="button" class="header__search-close" data-header-search-close="{{ section.id }}" aria-label="Close search">×</button>
          <div id="predictive-search-results-header" tabindex="-1" class="predictive-search-box"></div>
        </form>
      </predictive-search>
    </div>
  {% endif %}

  {% assign menu = section.settings.menu %}
  {% if menu != blank and menu.links.size > 0 %}
    <nav class="header-nav-bar">
      <div class="page-width header-nav-bar__inner">
        {% for link in menu.links %}
          <div class="header-nav-item">
            <a href="{{ link.url }}" class="header-nav-bar__link">{{ link.title }}</a>
            {% if link.links != blank and link.links.size > 0 %}
              <div class="header-mega">
                <div class="header-mega__inner">
                  {% for child_link in link.links %}
                    <div class="header-mega__column">
                      <a href="{{ child_link.url }}" class="header-mega__heading">{{ child_link.title }}</a>
                      {% if child_link.links != blank and child_link.links.size > 0 %}
                        <ul class="header-mega__list">
                          {% for grandchild_link in child_link.links %}
                            <li><a href="{{ grandchild_link.url }}">{{ grandchild_link.title }}</a></li>
                          {% endfor %}
                        </ul>
                      {% endif %}
                    </div>
                  {% endfor %}
                </div>
              </div>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    </nav>
  {% endif %}

  {% if section.settings.search_enabled %}
    <script>
      (function() {
        function initHeaderSearch() {
          var sectionId = {{ section.id | json }};
          var toggle = document.querySelector('[data-header-search-toggle="' + sectionId + '"]');
          var wrapper = document.querySelector('[data-header-search-wrapper="' + sectionId + '"]');
          var closeButton = document.querySelector('[data-header-search-close="' + sectionId + '"]');
          if (!toggle || !wrapper) return;

          function setOpen(open) {
            wrapper.classList.toggle('is-open', open);
            toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
            if (open) {
              var input = wrapper.querySelector('input[type="search"]');
              if (input) input.focus();
            }
          }

          toggle.addEventListener('click', function(event) {
            event.preventDefault();
            setOpen(!wrapper.classList.contains('is-open'));
          });

          if (closeButton) {
            closeButton.addEventListener('click', function(event) {
              event.preventDefault();
              setOpen(false);
            });
          }
        }

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', initHeaderSearch);
        } else {
          initHeaderSearch();
        }
      })();
    </script>
  {% endif %}
</header>
{% schema %}
{
  "name": "Header",
  "class": "section-header",
  "settings": [
    {
      "type": "checkbox",
      "id": "search_enabled",
      "label": "Enable search",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_announcement",
      "label": "Show announcement bar",
      "default": true
    },
    {
      "type": "text",
      "id": "announcement_text",
      "label": "Announcement text",
      "default": "Buy any 2 handbags and get extra 10% OFF"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu"
    },
    {
      "type": "select",
      "id": "logo_position",
      "options": [
        {
          "value": "top-left",
          "label": "Top Left"
        },
        {
          "value": "top-center",
          "label": "Top Center"
        },
        {
          "value": "middle-left",
          "label": "Middle Left"
        },
        {
          "value": "middle-center",
          "label": "Middle Center"
        }
      ],
      "default": "middle-left",
      "label": "Logo Position"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Margin Bottom",
      "default": 0
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 36,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 36,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "Default",
      "category": "Header"
    }
  ]
}
{% endschema %}